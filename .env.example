# Berkshire Energy — environment variables
# Copy to .env.local for local dev, and add the same keys in your host's
# project settings (e.g. Vercel → Settings → Environment Variables) for production.
#
# All of these are OPTIONAL. Without them the site still builds and runs —
# the quote form and support chat just won't email you (they log a warning instead).

# Resend API key — sends quote/support submissions to your inbox.
# Create at https://resend.com → API Keys. You already use Resend for this domain.
RESEND_API_KEY=

# Where lead/support emails are delivered. Single address or comma-separated list.
LEAD_EMAIL=afrancis@berkshireenergy.info

# From address for outgoing mail. Must be a Resend-verified domain/sender.
# Falls back to Resend's shared sender if unset.
LEAD_FROM=Berkshire Energy <onboarding@resend.dev>
